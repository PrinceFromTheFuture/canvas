{
  "name": "ai-report-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal canvas-style tool: upload data, AI authors a report in a constrained JSX vocabulary that renders to web + PDF from one source, shareable by link.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm --workspace @arb/db run generate",
    "db:migrate": "npm --workspace @arb/db run migrate",
    "dev:web": "npm --workspace @arb/web run dev",
    "dev:worker": "npm --workspace @arb/worker run dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
