# Postgres (durable store: reports, datasets, runs)
# Prefer 127.0.0.1 over localhost on Windows (localhost -> IPv6 ::1 can time
# out against Docker's IPv4-published port).
DATABASE_URL=postgres://arb:arb@127.0.0.1:5432/arb

# Redis (streaming backbone: per-run chunk stream + job queue + cancel flags)
REDIS_URL=redis://127.0.0.1:6379

# AI provider (pluggable). AI_PROVIDER one of: deepseek | openai | anthropic
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local dataset storage dir (object storage stand-in for dev)
STORAGE_DIR=.storage

# Public app URL (used to build shareable links)
APP_URL=http://localhost:3000

# Auth signing secret
AUTH_SECRET=dev-only-change-me
